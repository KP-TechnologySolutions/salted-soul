# Salted Soul — environment variables
# Copy this file to `.env.local` and fill in real values. `.env.local` is gitignored.

# ── Shopify (headless Storefront API) ────────────────────────────────────────
# These power the cart → Shopify-hosted checkout handoff.
#
# Store domain — the *.myshopify.com domain (NOT the public storefront domain).
#   e.g. salted-soul.myshopify.com
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=

# Public Storefront API access token. Generated by the Headless sales channel
# (or a custom app with Storefront API scopes). This token is read/checkout only
# and is SAFE to expose in client code — it is NOT the Admin API token.
# See docs/SHOPIFY-SETUP.md for how to generate it.
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=

# Optional — Storefront API version. Defaults to a recent stable version in code.
# NEXT_PUBLIC_SHOPIFY_API_VERSION=2025-10
